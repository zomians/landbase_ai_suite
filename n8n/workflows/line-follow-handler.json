    {
      "parameters": {
        "jsCode": "// 親ワークフローから受け取ったWebhookデータを使用\nconst webhookData = $input.first().json;\n\nreturn [{\n  json: {\n    line_user_id: webhookData.body.events[0].source.userId,\n    customer_name: \"未設定\",\n    drive_folder_id: \"\",\n    sheet_id: \"\",\n    accounting_soft: \"freee\",\n    registration_date: new Date().toISOString()\n  }\n}];"
      },
