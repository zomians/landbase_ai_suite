<%# shared/_badge.html.erb
  Required:
    label:   String — バッジテキスト
  Optional:
    variant: :success(default) / :info / :warning / :danger / :neutral / :purple
    size:    :sm(default) / :md
%>
<%
  variant = local_assigns.fetch(:variant, :success).to_sym
  size    = local_assigns.fetch(:size, :sm).to_sym

  variant_classes = {
    success: "bg-green-100 text-green-800",
    info:    "bg-blue-100 text-blue-800",
    warning: "bg-yellow-100 text-yellow-800",
    danger:  "bg-red-100 text-red-800",
    neutral: "bg-gray-100 text-gray-700",
    purple:  "bg-purple-100 text-purple-700",
  }

  size_classes = {
    sm: "px-2 py-0.5 text-xs",
    md: "px-3 py-1 text-sm",
  }

  css = ["inline-flex items-center rounded-full font-medium", variant_classes[variant], size_classes[size]].join(" ")
%>
<span class="<%= css %>"><%= label %></span>
